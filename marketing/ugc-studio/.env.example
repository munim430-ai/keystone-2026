# Keystone UGC Studio — all optional. Copy to .env and fill what you use.
# With NOTHING set, the studio renders captioned Bangla videos with a silent
# voiceover track (add voice in your editor). That already works.

# ── Voiceover ─────────────────────────────────────────────────────────────
UGC_TTS_PROVIDER=auto        # auto | sarvam | indicf5 | parler | mms | silent
                             # auto = sarvam if key set, else silent
SARVAM_API_KEY=              # best Bangla quality (same as voice-agent); cloud
SARVAM_TTS_MODEL=bulbul:v2

# Local Bangla voice cloning (GPU box) — AI4Bharat IndicF5
UGC_INDICF5_REF_WAV=         # path to a clean 10-30s Bangla reference clip
UGC_INDICF5_REF_TXT=         # transcript of that reference clip

# ── Talking-head avatar (GPU box, optional) ───────────────────────────────
UGC_AVATAR_PROVIDER=none     # none | wav2lip | sadtalker
UGC_WAV2LIP_REPO=            # path to a cloned Rudrabha/Wav2Lip
UGC_WAV2LIP_CHECKPOINT=      # path to wav2lip_gan.pth
UGC_SADTALKER_REPO=          # path to a cloned OpenTalker/SadTalker

# ── Output ────────────────────────────────────────────────────────────────
UGC_OUT_DIR=                 # default: ./out
UGC_FPS=24

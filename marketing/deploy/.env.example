# Copy to .env and fill. NEVER commit the real .env (see marketing/.gitignore).

# --- Postgres (shared by all services) ---
PG_USER=keystone
PG_PASSWORD=change_me_strong

# --- Public URLs (set to your VPS host / reverse-proxy) ---
NOCODB_URL=https://nocodb.your-vps
N8N_HOST=n8n.your-vps
N8N_WEBHOOK_URL=https://n8n.your-vps/
POSTIZ_URL=https://postiz.your-vps
CHATWOOT_URL=https://inbox.your-vps

# --- Secrets (generate: openssl rand -hex 32) ---
POSTIZ_JWT_SECRET=change_me
UMAMI_APP_SECRET=change_me
CHATWOOT_SECRET=change_me

# --- NocoDB API (Account -> Tokens) + table ids (Table -> Details) ---
NOCODB_TOKEN=
NOCODB_STUDENTS_TABLE=
NOCODB_B2B_TABLE=

# --- Evolution API (WhatsApp — deployed separately) ---
EVOLUTION_API_URL=https://evo.your-vps
EVOLUTION_INSTANCE=keystone
EVOLUTION_API_KEY=
STAFF_WHATSAPP=8801XXXXXXXXX

# --- Facebook auto-poster (bots/fb_poster.py) ---
HF_API_TOKEN=
FB_PAGE_TOKEN=

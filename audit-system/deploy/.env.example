# Copy to .env and fill every value. NEVER commit the real .env.
# Generate secrets with: openssl rand -hex 32

# ---- Paperless-ngx (Phase 1) ----
PAPERLESS_PORT=8000
PAPERLESS_URL=http://your-vps-ip:8000
PAPERLESS_DB_PASSWORD=CHANGE_ME_db_pw
PAPERLESS_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=CHANGE_ME_strong_pw

# ---- NocoDB (Phase 1) ----
NOCODB_PORT=8080
NOCODB_DB_PASSWORD=CHANGE_ME_db_pw
NOCODB_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# ---- n8n (Phase 2) ----
N8N_PORT=5678
N8N_HOST=your-vps-ip
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://your-vps-ip:5678/
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- DocuSeal (Phase 2) ----
DOCUSEAL_PORT=3000
DOCUSEAL_HOST=your-vps-ip:3000
DOCUSEAL_SECRET_KEY_BASE=CHANGE_ME_openssl_rand_hex_64

# ---- Bigcapital (Phase 2) ----
BIGCAPITAL_PORT=4000
BIGCAPITAL_DB_ROOT_PASSWORD=CHANGE_ME_db_root_pw
BIGCAPITAL_DB_PASSWORD=CHANGE_ME_db_pw
BIGCAPITAL_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
BIGCAPITAL_BASE_CURRENCY=BDT

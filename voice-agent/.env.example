# ── Keystone Voice Agent ──────────────────────────────────────────────
# Copy this file to .env and fill in. Anything left blank falls back to
# demo/mock providers, so the whole system runs with ZERO keys for testing.

# Master switches ------------------------------------------------------
DEMO_MODE=1                 # 1 = mock STT/LLM/TTS + no real calls. Set 0 to go live.
DIALER_MODE=assist          # assist = you click "Call next" on the dashboard (recommended)
                            # auto   = scheduler dials by itself within business hours

# Server ---------------------------------------------------------------
HOST=127.0.0.1
PORT=8080
PUBLIC_HOST=                # public hostname Twilio can reach, e.g. abc123.ngrok-free.app
API_TOKEN=                  # optional: protects the dashboard API if you expose it

# Twilio ---------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=         # your Twilio number, E.164 (+1..., or a BD-friendly number)
RECORD_CALLS=1
AMD_ENABLED=0               # answering machine detection (adds ~$0.0075/call)

# LLM (the brain) ------------------------------------------------------
LLM_PROVIDER=auto           # auto | groq | nim | mock
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
NIM_API_KEY=                # NVIDIA NIM (OpenAI-compatible), optional alternative
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.3-70b-instruct

# STT ------------------------------------------------------------------
STT_PROVIDER=auto           # auto | groq_whisper | sarvam | mock
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5

# TTS ------------------------------------------------------------------
TTS_PROVIDER=auto           # auto | sarvam | mock
SARVAM_TTS_MODEL=bulbul:v2  # switch to bulbul:v3 once your account has it
SARVAM_TTS_SPEAKER=anushka

# Persona --------------------------------------------------------------
PERSONA_NAME=মায়া
OFFICIAL_WHATSAPP=01328-224600
OFFICE_LOCATION=নরসিংদী বাজার
DISCLOSE_AI_UPFRONT=0       # 1 = she introduces herself as an AI assistant in the greeting.
                            # Even at 0 she NEVER denies being an AI if asked. (hard rule)

# Calling policy -------------------------------------------------------
TIMEZONE=Asia/Dhaka
CALL_HOURS_START=10         # 10:00 local
CALL_HOURS_END=18           # stop at 18:00 local
DAILY_CALL_CAP=20
MIN_GAP_SECONDS=180         # minimum gap between two dials (jitter is added)
MAX_ATTEMPTS=3              # per center, then it is parked as "exhausted"
MAX_CALL_SECONDS=420        # hard cap per call
OPERATOR_PHONE=             # your own number, E.164 — used for test calls & transfers

# Notifications (optional) --------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tuning (defaults are sane) ------------------------------------------
VAD_SILENCE_MS=600
VAD_MIN_SPEECH_MS=240
VAD_RMS_FLOOR=260
BARGE_IN_MS=160
FILLER_AFTER_MS=900
DB_PATH=keystone_voice.db
